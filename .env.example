# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SEO_ENGINE_PATH: Optional absolute path to external SEO JSON output folder.
# If omitted, vite.config.ts falls back to the current local dev default path.
VITE_SEO_ENGINE_PATH="C:/Users/ricca/Desktop/DataCost-SEO-Engine/seo-engine/output/data-problems"

# Ad display modes:
# Mode 1: Current mode - AdSense pending, Freehub house promos enabled
VITE_ADSENSE_APPROVED="false"
VITE_ENABLE_HOUSE_ADS="true"
VITE_ENABLE_MANUAL_AD_SLOTS="true"

# Mode 2: AdSense approved - manual slots disabled because Auto ads handle placement
# VITE_ADSENSE_APPROVED="true"
# VITE_ENABLE_HOUSE_ADS="false"
# VITE_ENABLE_MANUAL_AD_SLOTS="false"

# Mode 3: AdSense approved - manual slots enabled for future manual AdSense units
# VITE_ADSENSE_APPROVED="true"
# VITE_ENABLE_HOUSE_ADS="false"
# VITE_ENABLE_MANUAL_AD_SLOTS="true"

# Optional: override the Freehub house-promo destination.
VITE_FREEHUB_PROMO_URL="https://freehub.co.za/"
