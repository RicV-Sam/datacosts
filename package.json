{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "update:fibre-prices": "tsx scripts/update-fibre-prices.ts",
    "check:fibre-prices": "tsx scripts/check-fibre-prices.ts",
    "submit:bing": "node scripts/submit-bing.mjs",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "check:data-problems": "tsx scripts/check-data-problems-publishing.ts",
    "audit:gsc-coverage": "node scripts/audit-gsc-coverage.mjs",
    "check:seo": "tsx scripts/check-seo-output.ts",
    "check:adsense": "tsx scripts/check-adsense-output.ts",
    "build": "npm run check:data-problems && npm run check:fibre-prices && npm run generate:sitemap && vite build && npm run check:seo && npm run check:adsense",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/browser-chromium": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
